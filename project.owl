  <rdf:Description rdf:about="http://www.semanticweb.org/nikos/ontologies/2026/6/untitled-ontology-29#hasCaptain">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
