    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>born in</rdfs:label>
    <rdfs:comment>Relates a Character to the Location of their birth. Functional: a character is born in exactly one place.</rdfs:comment>
