  <rdf:Description rdf:about="http://www.semanticweb.org/nikos/ontologies/2026/6/untitled-ontology-29#hasEaten">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
    <rdfs:label>has eaten</rdfs:label>
    <rdfs:comment>Relates a Character to the DevilFruit they have consumed. Functional (one character eats at most one Devil Fruit under the 'one fruit per body' rule) and InverseFunctional (each specific fruit individual can be eaten by at most one character, since only one exists at a time).</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/nikos/ontologies/2026/6/untitled-ontology-29#Character"/>
    <rdfs:range rdf:resource="http://www.semanticweb.org/nikos/ontologies/2026/6/untitled-ontology-29#DevilFruit"/>
  </rdf:Description>
