  <rdf:Description rdf:about="http://www.semanticweb.org/nikos/ontologies/2026/6/untitled-ontology-29#locatedIn">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <rdfs:label>located in</rdfs:label>
    <rdfs:comment>Relates a Location to a broader Location that contains it (e.g. an Island locatedIn a Sea). Transitive. (Asymmetry/irreflexivity are not declared here because OWL 2 forbids asymmetric/irreflexive axioms on transitive -- i.e. non-simple -- properties; the intended irreflexivity is instead enforced informally by never asserting a Location locatedIn itself.)</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/nikos/ontologies/2026/6/untitled-ontology-29#Location"/>
    <rdfs:range rdf:resource="http://www.semanticweb.org/nikos/ontologies/2026/6/untitled-ontology-29#Location"/>
  </rdf:Description>
