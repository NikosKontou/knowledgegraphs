  <rdf:Description rdf:about="http://www.semanticweb.org/nikos/ontologies/2026/6/untitled-ontology-29#GrandLineNative">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment>DEFINED CLASS. A Character whose birth Location is the Grand Line itself OR any Location transitively locatedIn the Grand Line (e.g. an island in the New World). Demonstrates inference through the bornInRegion property chain (bornIn o locatedIn) combined with the transitivity of locatedIn.</rdfs:comment>
    <owl:equivalentClass rdf:nodeID="n4fe50af84ed34c0ba80820471fa44140b104"/>
  </rdf:Description>
